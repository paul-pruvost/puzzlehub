{
  "name": "puzzlehub",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:up": "pnpm --parallel --filter \"./apps/*\" dev",
    "dev:web": "pnpm --filter @puzzlehub/web dev",
    "dev:api": "pnpm --filter @puzzlehub/api dev",
    "dev:db": "docker compose -f apps/api/docker-compose.yml up -d",
    "dev:down": "docker compose -f apps/api/docker-compose.yml down",
    "build": "pnpm -r build",
    "build:bank": "pnpm --filter @puzzlehub/api exec tsx scripts/build-offline-bank.ts",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "fast-check": "^4.8.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
