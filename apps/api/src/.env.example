# Copier en .env (jamais commité). Valeurs requises pour l'e2e live Google.
NODE_ENV=development
PORT=3000
WEB_ORIGIN=http://localhost:5173
# Secret de signature des cookies (≥ 32 caractères aléatoires)
COOKIE_SECRET=change-me-with-a-long-random-string-32+
# Identifiants OAuth Google (console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
SESSION_TTL_HOURS=168
