# --- puzzlehub api : variables d'environnement ---
# Copier en `.env` (non commité) et compléter.

# Auth & app (validées au boot, cf. src/config/env.ts)
NODE_ENV=development
PORT=3000
WEB_ORIGIN=http://localhost:5173
COOKIE_SECRET=change-me-au-moins-32-caracteres-aleatoires
# PLAY_TOKEN_SECRET=optionnel-distinct-du-cookie-secret-32+
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxx
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
SESSION_TTL_HOURS=168
TRUST_PROXY_HOPS=0

# Persistance auth (APRISMA-D-2) : si défini → stores Prisma/Postgres ; sinon in-memory.
# Postgres local : `docker compose -f apps/api/docker-compose.yml up -d`
DATABASE_URL=postgresql://puzzlehub:puzzlehub@localhost:5432/puzzlehub?schema=public
